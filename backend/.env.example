# 环境变量配置示例
# 复制此文件为 .env 并填入你的真实配置

# 阿里云百炼 API 配置
DASHSCOPE_API_KEY=sk-your-api-key-here

# 应用配置
APP_NAME=LangChainRAG
APP_VERSION=1.0.0
DEBUG=true

# 数据库 (SQLite文件路径，默认在backend目录下)
DATABASE_URL=sqlite+aiosqlite:///./app.db

# JWT 密钥 (生产环境请更换为随机字符串)
SECRET_KEY=dev-secret-key-change-in-production

# 服务端口
BACKEND_PORT=8000
FRONTEND_PORT=5173
